---
const { title } = Astro.props;
const user = Astro.locals.user;
const org = Astro.locals.org;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title} | Blamphs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="bg-navy-950 text-ink-100 font-sans antialiased flex min-h-screen">
  
  <aside class="w-64 border-r border-navy-800 bg-navy-900 flex flex-col hidden md:flex">
    <div class="h-16 flex items-center px-6 border-b border-navy-800">
      <a href="/dashboard" class="flex items-center gap-2 font-bold">
        <span class="w-6 h-6 rounded bg-gradient-to-br from-money-500 to-money-700 flex items-center justify-center text-navy-950 font-black text-xs">B</span>
        <span>blamphs</span>
      </a>
    </div>
    
    <div class="px-6 py-4 flex-1">
      <div class="text-xs text-ink-400 font-medium mb-2 uppercase tracking-wider">Organisation</div>
      <div class="flex items-center justify-between mb-6">
        <span class="font-semibold truncate">{org?.name}</span>
        <span class="px-2 py-0.5 rounded text-[10px] uppercase font-bold bg-navy-800 text-money-500">{org?.plan}</span>
      </div>

      <nav class="space-y-1">
        <a href="/dashboard" class="flex items-center gap-3 px-3 py-2 rounded-md bg-navy-800 text-money-500 font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          Overview
        </a>
        <a href="/api-keys" class="flex items-center gap-3 px-3 py-2 rounded-md text-ink-300 hover:bg-navy-800 hover:text-ink-100 transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
          API Keys
        </a>
        <a href="/billing" class="flex items-center gap-3 px-3 py-2 rounded-md text-ink-300 hover:bg-navy-800 hover:text-ink-100 transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
          Billing
        </a>
        <a href="/settings" class="flex items-center gap-3 px-3 py-2 rounded-md text-ink-300 hover:bg-navy-800 hover:text-ink-100 transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          Settings
        </a>
      </nav>
    </div>

    <div class="p-4 border-t border-navy-800">
      <div class="text-sm truncate text-ink-200 mb-3">{user?.email}</div>
      <form method="POST" action="/api/auth/logout">
        <button class="w-full text-left px-3 py-2 rounded-md text-ink-300 hover:bg-navy-800 hover:text-red-400 transition text-sm flex items-center gap-2">
          Sign out
        </button>
      </form>
    </div>
  </aside>

  <main class="flex-1 flex flex-col min-h-screen max-w-full overflow-hidden">
    <header class="h-16 border-b border-navy-800 bg-navy-950/50 backdrop-blur-sm flex items-center px-8 md:hidden">
      <a href="/dashboard" class="font-bold">blamphs</a>
    </header>
    <div class="flex-1 overflow-y-auto p-8">
      <slot />
    </div>
  </main>
</body>
</html>
