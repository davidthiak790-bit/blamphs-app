---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="API Keys">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">API Keys & Routing</h1>
    <p class="text-ink-300 mt-1">Connect your applications to the Blamphs proxy.</p>
  </div>

  <div class="bg-navy-900 border border-navy-800 rounded-xl p-8 mb-8">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-lg font-bold">Proxy Keys</h2>
      <button class="px-4 py-2 rounded-lg bg-money-500 text-navy-950 font-semibold text-sm hover:bg-money-400 transition" disabled>Create Key (Coming Sprint 3)</button>
    </div>
    
    <div class="text-center py-12 border-2 border-dashed border-navy-700 rounded-lg">
      <p class="text-ink-300">No API keys created yet.</p>
    </div>
  </div>

  <div class="bg-navy-900 border border-navy-800 rounded-xl p-8">
    <h2 class="text-lg font-bold mb-4">Integration Example (Anthropic)</h2>
    <div class="bg-navy-950 border border-navy-800 rounded-lg p-4 font-mono text-sm overflow-x-auto text-ink-200">
      <span class="text-purple-400">import</span> Anthropic <span class="text-purple-400">from</span> <span class="text-green-400">'@anthropic-ai/sdk'</span>;<br/><br/>
      <span class="text-purple-400">const</span> client = <span class="text-purple-400">new</span> Anthropic(&#123;<br/>
      &nbsp;&nbsp;apiKey: process.env.<span class="text-blue-300">ANTHROPIC_API_KEY</span>,<br/>
      &nbsp;&nbsp;<span class="text-ink-400">// Point traffic through your Blamphs proxy</span><br/>
      &nbsp;&nbsp;baseURL: <span class="text-green-400">'https://proxy.blamphs.ai/v1'</span>,<br/>
      &nbsp;&nbsp;defaultHeaders: &#123;<br/>
      &nbsp;&nbsp;&nbsp;&nbsp;<span class="text-green-400">'x-blamphs-key'</span>: process.env.<span class="text-blue-300">BLAMPHS_API_KEY</span><br/>
      &nbsp;&nbsp;&#125;<br/>
      &#125;);
    </div>
  </div>
</AppLayout>
